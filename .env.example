# Сессия исполнителя (минимум 32 символа) — обязательно везде
SESSION_SECRET=your-super-secret-session-key-at-least-32-chars-long

# Локальная разработка: оставьте пустым — база создастся в data/app.db
# Vercel (продакшен): укажите Turso — бесплатный SQLite в облаке
# https://turso.tech — создайте БД, скопируйте URL и токен
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=
